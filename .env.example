# =============================================================================
# CVision — Environment Configuration Template
# Copy this file to .env and fill in your values.
# The .env file should NEVER be committed to version control.
# =============================================================================

# ── Google Sheets Integration ─────────────────────────────────────────────────
# Find the Sheet ID in your Google Sheet URL:
#   https://docs.google.com/spreadsheets/d/THIS_PART_HERE/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Path to your Service Account JSON key file (downloaded from Google Cloud Console).
# See GOOGLE_FORM_SPEC.md for step-by-step setup instructions.
GOOGLE_CREDENTIALS_PATH=credentials.json

# ── Phase 2: LLM API Keys (leave blank — not needed for Phase 1) ──────────────
# The app auto-detects which key is set and uses that provider.
# GEMINI_API_KEY=your_gemini_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Phase 2: Email Configuration (leave blank for now) ────────────────────────
# SMTP_EMAIL=your_gmail@gmail.com
# SMTP_APP_PASSWORD=your_16_char_app_password
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
